# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      # ZoomVideoSDK.xcframework has ios-arm64_x86_64-simulator slice,
      # so we remove arm64 exclusion to allow simulator builds on Apple Silicon
      config.build_settings.delete('EXCLUDED_ARCHS[sdk=iphonesimulator*]')
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'i386'
    end
  end

  # Fix: rive_native uses pod_target_xcconfig (not user_target_xcconfig), so its
  # Rive C++ linker flags are not propagated to the host app's final link step.
  # We manually add them to the Pods-Runner xcconfig files here.
  rive_root = "${PODS_ROOT}/../.symlinks/plugins/rive_native/native/build/iphoneos/bin"
  rive_libs = "-lc++ -lrive -lrive_pls_renderer -lrive_yoga -lrive_harfbuzz -lrive_sheenbidi" \
              " -lrive_decoders -llibpng -lzlib -llibjpeg -llibwebp -lminiaudio" \
              " -lluau_vm -lluau_compiler -lluau_analyzer -lrive_scripting_workspace -lbrotli"

  ['debug', 'profile', 'release'].each do |config_name|
    xcconfig_path = File.join(
      installer.sandbox.root,
      "Target Support Files/Pods-Runner/Pods-Runner.#{config_name}.xcconfig"
    )
    next unless File.exist?(xcconfig_path)
    content = File.read(xcconfig_path)
    next if content.include?('// Rive native library paths')

    content += "\n// Rive native library paths (propagated from rive_native pod_target_xcconfig)"
    content += "\nLIBRARY_SEARCH_PATHS[sdk=iphonesimulator*] = $(inherited) \"#{rive_root}/emulator\""
    content += "\nLIBRARY_SEARCH_PATHS[sdk=iphoneos*] = $(inherited) \"#{rive_root}/release\""
    content += "\nOTHER_LDFLAGS[sdk=iphonesimulator*] = $(inherited) -Wl,-force_load,#{rive_root}/emulator/librive_native.a #{rive_libs}"
    content += "\nOTHER_LDFLAGS[sdk=iphoneos*] = $(inherited) -Wl,-force_load,#{rive_root}/release/librive_native.a #{rive_libs}"
    File.write(xcconfig_path, content)
  end
end
